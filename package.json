{
  "name": "cs2vault",
  "version": "2.0.0",
  "description": "CS2 Portfolio Tracker — Professional Investment Dashboard",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder --win --publish never",
    "release": "electron-builder --win --publish always"
  },
  "build": {
    "appId": "com.cs2vault.app",
    "productName": "CS2 Vault",
    "copyright": "CS2 Vault",
    "publish": [
      {
        "provider": "github",
        "owner": "Rudizzle123",
        "repo": "cs2vault-electron"
      }
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "CS2 Vault",
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "compression": "maximum"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.1.8"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  }
}